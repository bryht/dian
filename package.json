{
  "name": "dian",
  "version": "0.7.5",
  "private": true,
  "main": "main.cjs",
  "description": "a dictionary app",
  "homepage": ".",
  "author": {
    "name": "bryht",
    "email": "bryht@live.com"
  },
  "build": {
    "appId": "Dian",
    "productName": "Dian",
    "artifactName": "${productName}_Setup_${os}_${arch}.${ext}",
    "files": [
      "build/**/*",
      "main.cjs"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bryht",
        "repo": "dian",
        "releaseType": "release"
      }
    ],
    "extends": null,
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.33.0",
    "@electron/remote": "^2.1.2",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "bootstrap": "^5.3.3",
    "cheerio": "^1.0.0",
    "electron-json-storage": "^4.6.0",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "franc": "^6.2.0",
    "fs-extra": "^11.2.0",
    "google-tts-api": "^2.0.2",
    "jquery": "^3.7.1",
    "mousetrap": "^1.6.5",
    "pdfkit": "^0.15.1",
    "react": "^19.0.0",
    "react-bootstrap-typeahead": "^6.3.2",
    "react-dom": "^19.0.0",
    "react-modal": "^3.16.1",
    "react-redux": "^9.2.0",
    "react-transition-group": "^4.4.5",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/electron-json-storage": "^4.5.4",
    "@types/fs-extra": "^11.0.4",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-modal": "^3.16.3",
    "@types/react-transition-group": "^4.4.11",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-svgr": "^4.3.0",
    "wait-on": "^8.0.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "package": "electron-builder -wm --publish=always",
    "package-local": "electron-builder -w"
  }
}
