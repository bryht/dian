{
  "name": "dian",
  "version": "0.7.6",
  "private": true,
  "main": "electron/main.cjs",
  "description": "a dictionary app",
  "homepage": ".",
  "author": {
    "name": "bryht",
    "email": "bryht@live.com"
  },
  "build": {
    "appId": "Dian",
    "productName": "Dian",
    "artifactName": "${productName}_Setup_${os}_${arch}.${ext}",
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bryht",
        "repo": "dian",
        "releaseType": "release"
      }
    ],
    "extends": null,
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@ghostery/adblocker-electron": "^2.14.4",
    "cheerio": "^1.2.0",
    "electron-json-storage": "^4.6.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "franc": "^6.2.0",
    "fs-extra": "^11.3.4",
    "google-tts-api": "^2.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-json-storage": "^4.5.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "xvfb-run --auto-servernum --server-args=\"-screen 0 1280x800x24\" playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "package": "electron-builder -w --publish=always",
    "package-local": "electron-builder -w"
  }
}
