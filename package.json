{
  "name": "dian",
  "version": "0.7.6",
  "private": true,
  "main": "electron/main.cjs",
  "description": "a dictionary app",
  "homepage": ".",
  "author": {
    "name": "bryht",
    "email": "bryht@live.com"
  },
  "build": {
    "appId": "Dian",
    "productName": "Dian",
    "artifactName": "${productName}_Setup_${os}_${arch}.${ext}",
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bryht",
        "repo": "dian",
        "releaseType": "release"
      }
    ],
    "extends": null,
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.11.0",
    "@cliqz/adblocker-electron": "^1.33.0",
    "@electron/remote": "^2.1.2",
    "bootstrap": "^5.3.3",
    "cheerio": "^1.0.0",
    "electron-json-storage": "^4.6.0",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "franc": "^6.2.0",
    "fs-extra": "^11.2.0",
    "google-tts-api": "^2.0.2",
    "mousetrap": "^1.6.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-modal": "^3.16.1"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/electron-json-storage": "^4.5.4",
    "@types/fs-extra": "^11.0.4",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-modal": "^3.16.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sass": "^1.83.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vite-plugin-svgr": "^4.3.0",
    "wait-on": "^8.0.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "package": "electron-builder -w --publish=always",
    "package-local": "electron-builder -w"
  }
}
